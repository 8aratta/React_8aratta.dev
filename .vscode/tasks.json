{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Dev Server",
            "type": "npm",
            "script": "start",
            "path": "8aratta_dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Compiling...",
                    "endsPattern": "Compiled (successfully|with warnings)"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}